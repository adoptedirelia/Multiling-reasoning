{
  "run_name": "gpt_mkqa",
  "dataset": {
    "dataset_type": "mkqa",
    "mkqa_path": "ml-mkqa/dataset/mkqa.jsonl.gz",
    "langs": [
      "de",
      "es",
      "fi",
      "fr",
      "hu",
      "it",
      "ko",
      "nl",
      "pl",
      "pt",
      "ru",
      "sv",
      "tr",
      "zh_hk",
      "zh_tw",
      "ar",
      "da",
      "he",
      "ja",
      "km",
      "ms",
      "no",
      "th",
      "vi",
      "zh_cn"
    ],
    "max_examples": 30,
    "seed": 42
  },
  "models": {
    "reasoner_en": {
      "model_type": "openai",
      "model_name": "gpt-4o-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 300
      }
    },
    "mt2": {
      "model_type": "openai",
      "model_name": "gpt-4o-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 300
      }
    }
  },
  "corruption": {
    "input_jsonl": "results/error_prop_gpt/mkqa/mkqa_gpt_corruptions.jsonl",
    "output_jsonl": "results/error_prop_gpt/mkqa/mkqa_gpt_corruptions.jsonl"
  },
  "cascade": {
    "modes": [
      "standard",
      "context",
      "direct"
    ]
  },
  "eval": {
    "methods": [
      "f1",
      "chrf"
    ],
    "prediction_field": "prediction"
  },
  "outputs": {
    "predictions_jsonl": "results/gpt/mkqa/preds",
    "metrics_json": "results/gpt/mkqa/metrics/metrics.json",
    "logs_dir": "logs/gpt/mkqa"
  },
  "generation": {
    "mt1_max_new_tokens": 8192,
    "mt1_temperature": 0.0,
    "mt1_top_p": 1.0,
    "mt2_max_new_tokens": 8192,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0,
    "corruption_max_new_tokens": 8192,
    "corruption_temperature": 0.3,
    "corruption_top_p": 0.9
  }
}
