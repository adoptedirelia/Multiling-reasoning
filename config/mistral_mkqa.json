{
  "run_name": "final_mistral_mkqa",
  "dataset": {
    "dataset_type": "mkqa",
    "mkqa_path": "ml-mkqa/dataset/mkqa.jsonl.gz",
    "langs": [
      "de",
      "es",
      "fi",
      "fr",
      "hu",
      "it",
      "ko",
      "nl",
      "pl",
      "pt",
      "ru",
      "sv",
      "tr",
      "zh_hk",
      "zh_tw",
      "ar",
      "da",
      "he",
      "ja",
      "km",
      "ms",
      "no",
      "th",
      "vi",
      "zh_cn"
    ],
    "max_examples": 20000,
    "seed": 42
  },
  "models": {
    "reasoner_en": {
      "model_type": "mistral",
      "model_name": "mistralai/Mistral-7B-Instruct-v0.3",
      "engine_kwargs": {}
    },
    "mt2": {
      "model_type": "mistral",
      "model_name": "mistralai/Mistral-7B-Instruct-v0.3",
      "engine_kwargs": {}
    }
  },
  "corruption": {
    "input_jsonl": "results/error_prop_gpt/mkqa/mkqa_gpt_corruptions.jsonl",
    "output_jsonl": "results/error_prop_gpt/mkqa/mkqa_gpt_corruptions.jsonl"
  },
  "cascade": {
    "modes": [
      "standard",
      "context",
      "direct"
    ]
  },
  "eval": {
    "methods": [
      "f1",
      "chrf"
    ],
    "prediction_field": "prediction"
  },
  "outputs": {
    "predictions_jsonl": "results/mistral/mkqa/preds",
    "metrics_json": "results/mistral/mkqa/metrics/metrics.json",
    "logs_dir": "logs/mistral/mkqa"
  }
}
