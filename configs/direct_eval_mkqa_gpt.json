{
  "run_name": "mkqa_direct_eval_gpt",
  "dataset": {
    "dataset_type": "mkqa",
    "mkqa_path": "src/evaluation/error_prop/ml-mkqa/dataset/mkqa.jsonl.gz",
    "langs": [
      "zh_cn",
      "ar",
      "vi",
      "ja"
    ],
    "max_examples": 500,
    "seed": 42
  },
  "model": {
    "model_type": "openai",
    "model_name": "gpt-4.1-mini",
    "engine_kwargs": {
      "api_key_env": "OPENAI_API_KEY",
      "timeout_s": 120
    }
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_gpt/mkqa/preds",
    "metrics_dir": "results/direct_eval_gpt/mkqa/metrics",
    "logs_dir": "logs"
  }
}
