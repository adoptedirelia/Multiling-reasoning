{
  "run_name": "global_piqa_direct_eval_gpt",
  "dataset": {
    "dataset_type": "global_piqa",
    "langs": [
      "zh_cn",
      "ar",
      "ja",
      "vi",
      "te",
      "mr",
      "am"
    ],
    "max_examples": 1000,
    "seed": 42,
    "hf_name": "mrlbenchmarks/global-piqa-nonparallel",
    "hf_split": "test",
    "hf_configs": {
      "zh_cn": "cmn_hans",
      "ar": "arb_arab",
      "ja": "jpn_jpan",
      "vi": "vie_latn",
      "te": "tel_telu",
      "mr": "mar_deva",
      "am": "amh_ethi"
    }
  },
  "model": {
    "model_type": "openai",
    "model_name": "gpt-4.1-mini",
    "engine_kwargs": {
      "api_key_env": "OPENAI_API_KEY",
      "timeout_s": 120
    }
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_gpt/global_piqa/preds",
    "metrics_dir": "results/direct_eval_gpt/global_piqa/metrics",
    "logs_dir": "logs"
  }
}
