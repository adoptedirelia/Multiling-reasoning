{
  "run_name": "aya_v2_example",
  "dataset": {
    "dataset_type": "aya",
    "langs": ["zho", "tel", "arb"],
    "max_examples": 200,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "zho": "aya_human_annotated",
      "tel": "aya_human_annotated",
      "arb": "aya_human_annotated"
    }
  },
  "models": {
    "reasoner_en": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    },
    "mt1": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    },
    "corruption_llm": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    },
    "mt2": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    }
  },
  "corruption": {
    "input_jsonl": "",
    "output_jsonl": "results/v2/aya/corruptions.jsonl"
  },
  "cascade": {
    "modes": ["standard", "context"]
  },
  "eval": {
    "methods": ["f1", "bleu", "bertscore"],
    "prediction_field": "prediction",
    "slice_field": "slice",
    "lang_field": "lang",
    "example_id_field": "example_id",
    "bertscore_model_type": "xlm-roberta-large",
    "bertscore_batch_size": 16,
    "bertscore_rescale_with_baseline": false
  },
  "outputs": {
    "corruption_jsonl": "results/v2/aya/corruptions.jsonl",
    "predictions_jsonl": "results/v2/aya/predictions.jsonl",
    "metrics_json": "results/v2/aya/metrics.json",
    "logs_dir": "logs"
  }
}

