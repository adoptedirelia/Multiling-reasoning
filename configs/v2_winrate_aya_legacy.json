{
  "run_name": "v2_winrate_aya_legacy",
  "dataset": {
    "dataset_type": "aya",
    "langs": ["zho", "tel", "arb"],
    "max_examples": 2000,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "zho": "aya_human_annotated",
      "tel": "aya_human_annotated",
      "arb": "aya_human_annotated"
    }
  },
  "models": {
    "reasoner_en": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    },
    "mt2": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    }
  },
  "eval": {
    "methods": ["win_rate"],
    "prediction_field": "y_l",
    "win_judge_model_name": "gpt-4.1-mini",
    "win_judge_api_key_env": "OPENAI_API_KEY",
    "win_judge_timeout_s": 120,
    "win_max_new_tokens": 8,
    "win_temperature": 0.0,
    "win_top_p": 1.0
  },
  "outputs": {
    "metrics_json": "results/v2/winrate/aya_legacy_winrate.json",
    "logs_dir": "logs"
  }
}

