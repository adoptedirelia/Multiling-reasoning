{
  "run_name": "mkqa_error_sim2",
  "dataset": {
    "mkqa_path": "src/evaluation/error_prop/ml-mkqa/dataset/mkqa.jsonl.gz",
    "langs": ["zh_cn", "ar", "vi", "ja"],
    "max_examples": 100,
    "seed": 42
  },
  "models": {
    "reasoner_en": {
      "model_type": "llama",
      "model_name": "meta-llama/Llama-3.1-8B-Instruct",
      "max_new_tokens": 256,
      "temperature": 0.0,
      "top_p": 1.0
    },
    "corruption_llm": {
      "model_type": "llama",
      "model_name": "meta-llama/Llama-3.1-8B-Instruct",
      "max_new_tokens": 256,
      "temperature": 0.0,
      "top_p": 1.0
    },
    "MT2": {
      "model_type": "llama",
      "model_name": "meta-llama/Llama-3.1-8B-Instruct",
      "max_new_tokens": 256,
      "temperature": 0.0,
      "top_p": 1.0
    }
  },
  "corruption": {
    "num_variants_per_error": 1,
    "omission_max_words": 2,
    "require_all_errors": true,
    "max_output_variants_per_type": 6,
    "input_jsonl": null,
    "output_jsonl": "results/error_sim/corruptions/mkqa_full_corruptions.jsonl"
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0,
    "corruption_max_new_tokens": 256,
    "corruption_temperature": 0.3,
    "corruption_top_p": 0.9
  },
  "outputs": {
    "predictions_dir": "results/error_sim/preds",
    "metrics_dir": "results/error_sim/metrics",
    "logs_dir": "logs"
  }
}
