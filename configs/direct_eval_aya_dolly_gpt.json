{
  "run_name": "aya_dolly_direct_eval_gpt",
  "dataset": {
    "dataset_type": "aya",
    "langs": [
      "amh",
      "arb",
      "jpn",
      "mar",
      "zho",
      "tel",
      "vie"
    ],
    "max_examples": 24000,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "amh": "dolly_machine_translated",
      "arb": "dolly_machine_translated",
      "jpn": "dolly_machine_translated",
      "mar": "dolly_machine_translated",
      "zho": "dolly_machine_translated",
      "tel": "dolly_machine_translated",
      "vie": "dolly_machine_translated"
    }
  },
  "model": {
    "model_type": "openai",
    "model_name": "gpt-4.1-mini",
    "engine_kwargs": {
      "api_key_env": "OPENAI_API_KEY",
      "timeout_s": 120
    }
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_gpt/aya_dolly/preds",
    "metrics_dir": "results/direct_eval_gpt/aya_dolly/metrics",
    "logs_dir": "logs"
  }
}
