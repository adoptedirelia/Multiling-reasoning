{
  "run_name": "aya_dolly_direct_eval",
  "dataset": {
    "dataset_type": "aya",
    "langs": [
      "amh",
      "arb",
      "jpn",
      "mar",
      "zho",
      "tel",
      "vie"
    ],
    "max_examples": 24000,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "amh": "dolly_machine_translated",
      "arb": "dolly_machine_translated",
      "jpn": "dolly_machine_translated",
      "mar": "dolly_machine_translated",
      "zho": "dolly_machine_translated",
      "tel": "dolly_machine_translated",
      "vie": "dolly_machine_translated"
    }
  },
  "model": {
    "model_type": "qwen3",
    "model_name": "Qwen/Qwen2.5-7B-Instruct",
    "device_map": "auto",
    "torch_dtype": "auto",
    "attn_implementation": "flash_attention_2"
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_aya_dolly/preds",
    "metrics_dir": "results/direct_eval_aya_dolly/metrics",
    "logs_dir": "logs"
  }
}
