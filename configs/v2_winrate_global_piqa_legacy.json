{
  "run_name": "v2_winrate_global_piqa_legacy",
  "dataset": {
    "dataset_type": "global_piqa",
    "langs": ["zh_cn", "ar", "ja", "vi", "te", "mr", "am"],
    "max_examples": 1000,
    "seed": 42,
    "hf_name": "mrlbenchmarks/global-piqa-nonparallel",
    "hf_split": "test",
    "hf_configs": {
      "zh_cn": "cmn_hans",
      "ar": "arb_arab",
      "ja": "jpn_jpan",
      "vi": "vie_latn",
      "te": "tel_telu",
      "mr": "mar_deva",
      "am": "amh_ethi"
    }
  },
  "models": {
    "reasoner_en": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    },
    "mt2": {
      "model_type": "openai",
      "model_name": "gpt-4.1-mini",
      "engine_kwargs": {
        "api_key_env": "OPENAI_API_KEY",
        "timeout_s": 120
      }
    }
  },
  "eval": {
    "methods": ["win_rate"],
    "prediction_field": "y_l",
    "win_judge_model_name": "gpt-4.1-mini",
    "win_judge_api_key_env": "OPENAI_API_KEY",
    "win_judge_timeout_s": 120,
    "win_max_new_tokens": 8,
    "win_temperature": 0.0,
    "win_top_p": 1.0
  },
  "outputs": {
    "metrics_json": "results/v2/winrate/global_piqa_legacy_winrate.json",
    "logs_dir": "logs"
  }
}

