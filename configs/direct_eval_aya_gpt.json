{
  "run_name": "aya_direct_eval_gpt",
  "dataset": {
    "dataset_type": "aya",
    "langs": [
      "zho",
      "tel",
      "arb"
    ],
    "max_examples": 2000,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "zho": "aya_human_annotated",
      "tel": "aya_human_annotated",
      "arb": "aya_human_annotated"
    }
  },
  "model": {
    "model_type": "openai",
    "model_name": "gpt-4.1-mini",
    "engine_kwargs": {
      "api_key_env": "OPENAI_API_KEY",
      "timeout_s": 120
    }
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_gpt/aya/preds",
    "metrics_dir": "results/direct_eval_gpt/aya/metrics",
    "logs_dir": "logs"
  }
}
