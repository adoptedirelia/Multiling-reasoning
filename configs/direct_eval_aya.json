{
  "run_name": "aya_direct_eval",
  "dataset": {
    "dataset_type": "aya",
    "langs": [
      "zho",
      "tel",
      "arb"
    ],
    "max_examples": 2000,
    "seed": 42,
    "hf_name": "CohereLabs/aya_evaluation_suite",
    "hf_split": "test",
    "hf_configs": {
      "zho": "aya_human_annotated",
      "tel": "aya_human_annotated",
      "arb": "aya_human_annotated"
    }
  },
  "model": {
    "model_type": "qwen3",
    "model_name": "Qwen/Qwen2.5-7B-Instruct",
    "device_map": "auto",
    "torch_dtype": "auto",
    "attn_implementation": "flash_attention_2"
  },
  "generation": {
    "mt2_max_new_tokens": 256,
    "mt2_temperature": 0.0,
    "mt2_top_p": 1.0
  },
  "outputs": {
    "predictions_dir": "results/direct_eval_aya/preds",
    "metrics_dir": "results/direct_eval_aya/metrics",
    "logs_dir": "logs"
  }
}
